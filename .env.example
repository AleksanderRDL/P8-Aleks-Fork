# Database
DATABASE_URL=postgresql://ais:aisdev@localhost:5433/ais

# AIS pipeline I/O
AIS_INPUT_FILE=AISDATA/aisdk-2026-02-05.csv
AIS_OUTPUT_PATH=AISDATA/aisdk-2026-02-05.cleaned.csv

# Spark tuning
SPARK_LOCAL_CORES=4
SPARK_SHUFFLE_PARTITIONS=64
SPARK_INPUT_PARTITION_MB=64
